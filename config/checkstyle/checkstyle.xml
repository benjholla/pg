<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
          "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
          "https://checkstyle.org">

<!-- 
    Checkstyle References:  
      - http://checkstyle.sourceforge.net/config.html
      - https://github.com/checkstyle/checkstyle/tree/master/src/main/resources
-->

<module name="Checker">

    <property name="charset" value="UTF-8"/>
 
    <!-- check no tabs -->
    <module name="FileTabCharacter">
        <property name="severity" value="error" />
    </module>

    <!-- check files end with new line -->
    <module name="NewlineAtEndOfFile">
        <property name="lineSeparator" value="lf" />
    </module>

    <!-- Java AST specific tests live under TreeWalker module -->
    <module name="TreeWalker">
        <!-- checks import statements -->
        <!-- note: import order is excluded from this list because it appears to
        be more trouble than it is worth -->
        <module name="AvoidStarImport">
            <property name="allowClassImports" value="false" />
            <property name="severity" value="error" />
        </module>
        <module name="RedundantImport">
            <property name="severity" value="error" />
        </module>
        <module name="UnusedImports" />

        <!-- checks for explicit braces around if and else blocks -->
        <module name="NeedBraces">
            <property name="severity" value="error" />
            <property name="tokens" value="LITERAL_IF, LITERAL_ELSE, LITERAL_FOR, LITERAL_WHILE, LITERAL_DO" />
        </module>

        <!-- 
            Check for falling through to the next case statement. Similar to
            javac -Xlint:fallthrough, but the check is suppressed if a single-line comment
            on the last non-blank line preceding the fallen-into case contains 'fall through'.
        -->
        <module name="FallThrough">
            <property name="reliefPattern"
                value="fall through|Fall through|falls through|Falls through|fallthrough|Fallthrough|fall-through" />
            <property name="severity" value="error" />
        </module>
    </module>

</module>